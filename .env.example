# Copy these values into Vercel Project Settings > Environment Variables.
# The browser receives only the URL and publishable/anon key through /api/config.
# Never add SUPABASE_SERVICE_ROLE_KEY to the browser or this file.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Older Supabase projects may expose an "anon" key instead. Use this name only
# when SUPABASE_PUBLISHABLE_KEY is unavailable.
# SUPABASE_ANON_KEY=your-supabase-anon-key
